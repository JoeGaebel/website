---
import "../styles/app.css"
import Navigation from "../components/Navigation.astro"

interface Props {
    title?: string
    description?: string
    canonicalPath?: string
    type?: string
    jsonLd?: Record<string, unknown>
    preloadImage?: string
    hideNav?: boolean
}

const siteUrl = "https://www.joegaebel.com"
const defaultDescription = "Joe Gaebel is a Full-Stack Engineer specialising in XP and TDD, based in Queensland, Australia."

const {
    title = "Joe Gaebel - Full-Stack Engineer",
    description = defaultDescription,
    canonicalPath,
    type = "website",
    jsonLd,
    preloadImage,
    hideNav = false,
} = Astro.props

const canonicalUrl = canonicalPath ? `${siteUrl}${canonicalPath}` : `${siteUrl}${Astro.url.pathname}`
const defaultJsonLd = {
    "@context": "https://schema.org",
    "@type": "Person",
    "name": "Joe Gaebel",
    "url": siteUrl,
    "jobTitle": "Full-Stack Engineer",
    "description": defaultDescription,
}
---
<!DOCTYPE html>
<html lang="en" class="pt-[3.25rem]">
<head>
    <meta charset="utf-8" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="theme-color" content="#000000" />
    <meta name="description" content={description} />

    {preloadImage && <link rel="preload" as="image" href={preloadImage} fetchpriority="high" />}
    <link rel="canonical" href={canonicalUrl} />

    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content={type} />
    <meta property="og:url" content={canonicalUrl} />

    <script type="application/ld+json" set:html={JSON.stringify(jsonLd || defaultJsonLd)} />

    <title>{title}</title>
</head>
<body>
    {!hideNav && <Navigation />}
    {hideNav && (
        <Fragment>
            <div class="site-home-link-bar"></div>
            <a href="/" class="site-home-link">Joe Gaebel</a>
        </Fragment>
    )}
    <main>
        <slot />
    </main>
    <script is:inline>
      (function() {
        var els = document.querySelectorAll('[data-github-stars]');
        if (!els.length) return;
        var repos = {};
        els.forEach(function(el) { repos[el.dataset.githubStars] = true; });
        Object.keys(repos).forEach(function(repo) {
          fetch('https://api.github.com/repos/' + repo)
            .then(function(r) { return r.ok ? r.json() : null; })
            .then(function(data) {
              if (!data || !data.stargazers_count) return;
              document.querySelectorAll('[data-github-stars="' + repo + '"] .github-card-star-count')
                .forEach(function(el) { el.textContent = data.stargazers_count; });
            })
            .catch(function() {});
        });
      })();
    </script>
    <!-- Google tag (gtag.js) -->
    <script async src="https://www.googletagmanager.com/gtag/js?id=G-P3521Y09DF" is:inline></script>
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());

      gtag('config', 'G-P3521Y09DF');
    </script>
</body>
</html>
