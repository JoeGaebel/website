---
import "../styles/app.css"
import Navigation from "../components/Navigation.astro"

interface Props {
    title?: string
    description?: string
    canonicalPath?: string
    type?: string
    jsonLd?: Record<string, unknown>
    preloadImage?: string
}

const siteUrl = "https://www.joegaebel.com"
const defaultDescription = "Joe Gaebel is a Full-Stack Engineer specialising in XP and TDD, based in Queensland, Australia."

const {
    title = "Joe Gaebel - Full-Stack Engineer",
    description = defaultDescription,
    canonicalPath,
    type = "website",
    jsonLd,
    preloadImage,
} = Astro.props

const canonicalUrl = canonicalPath ? `${siteUrl}${canonicalPath}` : `${siteUrl}${Astro.url.pathname}`
const defaultJsonLd = {
    "@context": "https://schema.org",
    "@type": "Person",
    "name": "Joe Gaebel",
    "url": siteUrl,
    "jobTitle": "Full-Stack Engineer",
    "description": defaultDescription,
}
---
<!DOCTYPE html>
<html lang="en" class="pt-[3.25rem]">
<head>
    <meta charset="utf-8" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="theme-color" content="#000000" />
    <meta name="description" content={description} />

    {preloadImage && <link rel="preload" as="image" href={preloadImage} fetchpriority="high" />}
    <link rel="canonical" href={canonicalUrl} />

    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content={type} />
    <meta property="og:url" content={canonicalUrl} />

    <script type="application/ld+json" set:html={JSON.stringify(jsonLd || defaultJsonLd)} />

    <title>{title}</title>
</head>
<body>
    <Navigation />
    <main>
        <slot />
    </main>
    <script is:inline>
        function loadGtag() {
            window.dataLayer = window.dataLayer || [];
            function gtag(){dataLayer.push(arguments);}
            gtag('js', new Date());
            gtag('config', 'G-PEYCKJPRR2');
            var s = document.createElement('script');
            s.src = 'https://www.googletagmanager.com/gtag/js?id=G-PEYCKJPRR2';
            s.async = true;
            document.body.appendChild(s);
        }
        if ('requestIdleCallback' in window) {
            requestIdleCallback(loadGtag, {timeout: 5000});
        } else {
            setTimeout(loadGtag, 3000);
        }
    </script>
</body>
</html>
