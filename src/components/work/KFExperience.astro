---
import {Image} from "astro:assets"
import WorkExperience from "./WorkExperience.astro"
import kffab from "../../assets/logos/kffab.png"
import afrArticle from "../../assets/logos/afr-article.png"

const principles = ["Principle-centered leadership", "Lean manufacturing"]
const technologies = ["React", "Next.js"]
---
<WorkExperience
    companyName="K&F Fabrications"
    city="Sunshine Coast, Australia"
    titles={["Backseat Director"]}
    dateString={["January 2025 to present"]}
    years=""
    imageContainerMarginRight="-1.5rem"
>
    <img slot="image" style="width: 68px; margin-top: -0.4rem; margin-right: 2rem; margin-bottom: 1rem; margin-left: 0rem" src={kffab.src} alt="K&F Fabrications logo" />
    <Fragment slot="description">
        <div class="mb-[0.8rem]"><p>K&F Fabrications is a small aluminium and steel fabrication business on the Sunshine Coast.</p><p>We fabricate gates, fences, privacy screens, and custom projects.</p></div>
        <div class="mb-[0.8rem]"><b>I build custom shop floor and business software</b>, handle IT and infrastructure, and work on streamlining operations around the shop. I work with my partner on strategy and operations, implementing equipment upgrades, and shaping our people practices (hiring, values/mission work, org-structure, incentives).</div>
        <div class="mb-[0.8rem]">In short - <b>I help modernize and scale a hands-on business outside my usual 9-to-5.</b></div>
        <div class="mt-6">The practices I help instil are:</div>
        <div class="mb-3">
            {principles.map(keyword => <span class="tag tag-success mr-1 mt-1 text-[1rem]">{keyword}</span>)}
        </div>
        <div class="mt-6">I build apps for the biz with:</div>
        <div class="mb-3">
            {technologies.map(keyword => <span class="tag tag-info mr-1 mt-1 text-[1rem]">{keyword}</span>)}
        </div>
        <div class="mt-6">Also, we were recently in the Australian Financial Review!</div>
        <div style="position: relative; width: 75%; overflow: hidden; margin-top: 2rem; margin-left: auto; margin-right: auto">
            <Image src={afrArticle} alt="AFR Article" style="width: 100%; display: block" width={1282} quality={90} />
            <div style="position: absolute; display: flex; align-items: flex-end; justify-content: center; bottom: 0; left: 0; width: 100%; height: 100%; padding-bottom: 0.5rem; background-image: linear-gradient(to bottom, transparent 0%, transparent 50%, white 100%)">
                <a href="https://www.afr.com/wealth/personal-finance/we-re-banking-on-a-boring-business-as-our-ticket-to-lifelong-wealth-20250811-p5mlxd" target="_blank" rel="noopener noreferrer">
                    <button class="btn">Read the AFR article</button>
                </a>
            </div>
        </div>
    </Fragment>
</WorkExperience>
