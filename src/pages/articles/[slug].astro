---
import BaseLayout from "../../layouts/BaseLayout.astro"
import {getCollection, render} from "astro:content"
import "../../styles/blog.css"

export async function getStaticPaths() {
    const posts = await getCollection("articles", ({data}) => !data.draft)
    return posts.map(post => ({
        params: {slug: post.id},
        props: {post},
    }))
}

function formatDate(date: string) {
    return new Date(date + "T00:00:00").toLocaleDateString("en-US", {year: "numeric", month: "long", day: "numeric"})
}

const {post} = Astro.props
const {Content, headings} = await render(post)
const tocHeadings = headings.filter(h => h.depth === 2 || h.depth === 3)
---
<BaseLayout
    title={`${post.data.title} - Joe Gaebel`}
    description={post.data.description}
    type="article"
    hideNav
    jsonLd={{
        "@context": "https://schema.org",
        "@type": "Article",
        "headline": post.data.title,
        "description": post.data.description,
        "datePublished": post.data.date,
        "author": {"@type": "Person", "name": "Joe Gaebel", "url": "https://www.joegaebel.com"},
    }}
>
    <div class="blog-post py-12 px-6 min-[1024px]:px-12">
        <a class="back-link" href="/articles">&larr; Back to articles</a>
        <p class="post-date">{formatDate(post.data.date)}</p>
        <div class="content">
            <h1>{post.data.title}</h1>
            {tocHeadings.length > 2 && (
                <nav class="toc">
                    <details>
                        <summary>Table of Contents</summary>
                        <ul>
                            {tocHeadings.map(h => (
                                <li class={h.depth === 3 ? "toc-h3" : ""}>
                                    <a href={`#${h.slug}`}>{h.text}</a>
                                </li>
                            ))}
                        </ul>
                    </details>
                </nav>
            )}
            <div class="content-body">
                <Content />
            </div>
        </div>
    </div>
    <script>
        import mermaid from "mermaid"
        document.querySelectorAll("pre.mermaid").forEach(el => {
            el.textContent = el.textContent!.replace(/\\n/g, "\n")
        })
        mermaid.initialize({startOnLoad: true})
    </script>
</BaseLayout>
