---
import BaseLayout from "../../layouts/BaseLayout.astro"
import {getCollection} from "astro:content"
import "../../styles/blog.scss"

function formatDate(date: string) {
    return new Date(date + "T00:00:00").toLocaleDateString("en-US", {year: "numeric", month: "long", day: "numeric"})
}

const posts = (await getCollection("articles", ({data}) => !data.draft)).sort((a, b) =>
    new Date(b.data.date).getTime() - new Date(a.data.date).getTime()
)
---
<BaseLayout title="Articles - Joe Gaebel" description="Articles on software engineering, TDD, and agile development by Joe Gaebel.">
    <div class="blog-listing section">
        <h1 class="blog-listing-title">Articles</h1>
        <div>
            {posts.map(post => (
                <div class="blog-listing-item">
                    <a href={`/articles/${post.id}`}>
                        <h2>{post.data.title}</h2>
                    </a>
                    <p class="post-date">{formatDate(post.data.date)}</p>
                    <a href={`/articles/${post.id}`} class="post-description">{post.data.description}</a>
                </div>
            ))}
        </div>
    </div>
</BaseLayout>
