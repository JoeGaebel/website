---
import BaseLayout from "../../layouts/BaseLayout.astro"
import {getCollection} from "astro:content"
import "../../styles/blog.scss"

const posts = (await getCollection("blog", ({data}) => !data.draft)).sort((a, b) =>
    new Date(b.data.date).getTime() - new Date(a.data.date).getTime()
)
---
<BaseLayout title="Blog - Joe Gaebel">
    <div class="blog-listing section">
        <h1 class="blog-listing-title">Blog</h1>
        <div>
            {posts.map(post => (
                <div class="blog-listing-item">
                    <a href={`/blog/${post.id}`}>
                        <h2>{post.data.title}</h2>
                    </a>
                    <p class="post-date">{post.data.date}</p>
                    <a href={`/blog/${post.id}`} class="post-description">{post.data.description}</a>
                </div>
            ))}
        </div>
    </div>
</BaseLayout>
